# ─────────────────────────────────────────────────────────────
# Banco de dados (PostgreSQL — NeonDB em produção)
# String de conexão fornecida pelo provedor do banco.
# ─────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://usuario:senha@host:5432/banco?sslmode=require"

# ─────────────────────────────────────────────────────────────
# NextAuth
# NEXTAUTH_SECRET: chave para assinar/criptografar a sessão (JWT).
#   Gere uma com: openssl rand -base64 32
# NEXTAUTH_URL: URL pública da aplicação.
#   Em desenvolvimento: http://localhost:3000
#   Em produção: a URL do deploy (ex.: https://fhit.vercel.app)
# ─────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="cole-aqui-uma-chave-aleatoria"
NEXTAUTH_URL="http://localhost:3000"
